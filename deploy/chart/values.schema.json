{
  "$schema": "http://json-schema.org/schema#",
  "type": "object",
  "properties": {
    "deployment": {
      "type": "object",
      "properties": {
        "gateway": {
          "type": "object",
          "properties": {
            "class": {
              "type": "string",
              "enum": ["node-port", "aws-eks"]
            },
            "domain": {
              "type": "string",
              "description": "Required when gateway.class is node-port"
            },
            "config": {
              "type": "object",
              "properties": {
                "secretName": {
                  "type": "string",
                  "description": "Name of a pre-existing Secret holding the gateway wireguard config under key \"config.yaml\". Empty = generate fresh keys in emptyDir."
                }
              }
            }
          },
          "required": ["class"],
          "allOf": [
            {
              "if": {
                "properties": {
                  "class": { "const": "node-port" }
                }
              },
              "then": {
                "required": ["domain"]
              }
            }
          ]
        }
      },
      "required": ["gateway"]
    }
  },
  "required": ["deployment"]
}
